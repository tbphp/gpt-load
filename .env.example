# HTTP server
HOST=0.0.0.0
PORT=3001
GRACEFUL_SHUTDOWN_TIMEOUT=10

# Persistent data. An empty DATABASE_DSN resolves to ${DATA_DIR}/gpt-load.db.
DATA_DIR=./data
DATABASE_DSN=

# Management authentication is required.
AUTH_KEY=

# Optional explicit master key. When empty, GPT-Load creates
# ${DATA_DIR}/encryption.key with 0600 permissions on POSIX or a current-user
# ACL on Windows; back it up securely.
ENCRYPTION_KEY=

# Optional Redis runtime-state store. Empty uses the in-memory implementation.
REDIS_DSN=

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
